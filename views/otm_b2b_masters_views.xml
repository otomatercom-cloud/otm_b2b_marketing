        <field name="arch" type="xml">
            <list string="MOU Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_otm_b2b_mou_type" model="ir.actions.act_window">
        <field name="name">MOU Types</field>
        <field name="res_model">otm.b2b.mou.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
