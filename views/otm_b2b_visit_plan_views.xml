<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_b2b_visit_plan_form" model="ir.ui.view">
        <field name="name">otm.b2b.visit.plan.form</field>
        <field name="model">otm.b2b.visit.plan</field>
        <field name="arch" type="xml">
            <form string="Visit Plan">
                <header>
                    <button name="action_confirm_plan" type="object" string="Confirm"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_check_in" type="object" string="Check In"
                            class="btn-primary" invisible="state != 'planned'"/>
                    <button name="action_open_complete_wizard" type="object" string="Complete Visit"
                            class="btn-primary" invisible="state not in ('draft', 'planned', 'in_progress')"/>
                    <button name="action_cancel_plan" type="object" string="Cancel"
                            invisible="state in ('completed', 'cancelled')"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,planned,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="institution_id" options="{'no_create': True}"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="visit_date"/>
                            <field name="expected_time" widget="float_time"/>
                            <field name="purpose"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="user_id"/>
                            <field name="visit_record_id" readonly="1" invisible="not visit_record_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_otm_b2b_visit_plan_list" model="ir.ui.view">
        <field name="name">otm.b2b.visit.plan.list</field>
        <field name="model">otm.b2b.visit.plan</field>
        <field name="arch" type="xml">
            <list string="Visit Plans" decoration-info="state == 'draft'"
                  decoration-warning="state == 'in_progress'"
                  decoration-success="state == 'completed'" decoration-muted="state == 'cancelled'">
                <field name="visit_date"/>
                <field name="institution_id"/>
                <field name="purpose"/>
                <field name="priority" widget="priority"/>
                <field name="user_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_otm_b2b_visit_plan_kanban" model="ir.ui.view">
        <field name="name">otm.b2b.visit.plan.kanban</field>
        <field name="model">otm.b2b.visit.plan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="institution_id"/>
                <field name="visit_date"/>
                <field name="priority"/>
                <field name="user_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="institution_id"/></strong>
                            <div><field name="visit_date"/></div>
                            <div><field name="user_id" widget="many2one_avatar_user"/></div>
                            <field name="priority" widget="priority"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_otm_b2b_visit_plan_search" model="ir.ui.view">
        <field name="name">otm.b2b.visit.plan.search</field>
        <field name="model">otm.b2b.visit.plan</field>
        <field name="arch" type="xml">
            <search string="Search Visit Plans">
                <field name="institution_id"/>
                <field name="user_id"/>
                <filter string="Today" name="filter_today"
                        domain="[('visit_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Upcoming" name="filter_upcoming"
                        domain="[('visit_date', '&gt;=', context_today().strftime('%Y-%m-%d')), ('state', '=', 'planned')]"/>
                <filter string="My Plans" name="filter_mine" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Planned" name="filter_planned" domain="[('state', '=', 'planned')]"/>
                <filter string="Checked In" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                <group>
                    <filter string="Assigned To" name="groupby_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Visit Date" name="groupby_date" context="{'group_by': 'visit_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_otm_b2b_visit_plan" model="ir.actions.act_window">
        <field name="name">Visit Planning</field>
        <field name="res_model">otm.b2b.visit.plan</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_mine': 1, 'search_default_filter_upcoming': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smart_action">Plan your next institution visit</p>
        </field>
    </record>

</odoo>
