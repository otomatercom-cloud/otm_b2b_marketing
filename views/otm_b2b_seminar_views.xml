<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_b2b_seminar_form" model="ir.ui.view">
        <field name="name">otm.b2b.seminar.form</field>
        <field name="model">otm.b2b.seminar</field>
        <field name="arch" type="xml">
            <form string="Seminar">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="topic" placeholder="Seminar Topic"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="institution_id" options="{'no_create': True}"/>
                            <field name="visit_id"/>
                            <field name="seminar_date"/>
                            <field name="speaker"/>
                        </group>
                        <group>
                            <field name="student_count"/>
                            <field name="faculty_count"/>
                            <field name="duration" widget="float_time"/>
                            <field name="interested_students"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Feedback &amp; Outcome" name="feedback">
                            <field name="feedback"/>
                            <field name="outcome"/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="photo" widget="image" class="oe_avatar"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_otm_b2b_seminar_list" model="ir.ui.view">
        <field name="name">otm.b2b.seminar.list</field>
        <field name="model">otm.b2b.seminar</field>
        <field name="arch" type="xml">
            <list string="Seminars">
                <field name="seminar_date"/>
                <field name="institution_id"/>
                <field name="topic"/>
                <field name="speaker"/>
                <field name="student_count"/>
                <field name="faculty_count"/>
            </list>
        </field>
    </record>

    <record id="view_otm_b2b_seminar_search" model="ir.ui.view">
        <field name="name">otm.b2b.seminar.search</field>
        <field name="model">otm.b2b.seminar</field>
        <field name="arch" type="xml">
            <search string="Search Seminars">
                <field name="topic"/>
                <field name="institution_id"/>
                <field name="speaker"/>
                <group>
                    <filter string="Institution" name="groupby_institution" context="{'group_by': 'institution_id'}"/>
                    <filter string="Seminar Date" name="groupby_date" context="{'group_by': 'seminar_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_otm_b2b_seminar" model="ir.actions.act_window">
        <field name="name">Seminar Management</field>
        <field name="res_model">otm.b2b.seminar</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smart_action">Record your first seminar</p>
        </field>
    </record>

</odoo>
