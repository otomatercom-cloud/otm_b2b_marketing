<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_b2b_activity_type_list" model="ir.ui.view">
        <field name="name">otm.b2b.activity.type.list</field>
        <field name="model">otm.b2b.activity.type</field>
        <field name="arch" type="xml">
            <list string="Activity Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="color" widget="color_picker" optional="hide"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_otm_b2b_activity_type_form" model="ir.ui.view">
        <field name="name">otm.b2b.activity.type.form</field>
        <field name="model">otm.b2b.activity.type</field>
        <field name="arch" type="xml">
            <form string="Activity Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="color" widget="color_picker"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_otm_b2b_activity_type" model="ir.actions.act_window">
        <field name="name">Activity Types</field>
        <field name="res_model">otm.b2b.activity.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
