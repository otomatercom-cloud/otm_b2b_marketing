<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_otm_b2b_mou_document">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>MOU Summary - <t t-esc="doc.institution_id.name"/></h2>
                    <table class="table table-sm table-borderless" style="width:100%;">
                        <tr>
                            <td><strong>Agreement Number:</strong> <t t-esc="doc.agreement_number or '-'"/></td>
                            <td><strong>Status:</strong> <t t-esc="doc.state"/></td>
                        </tr>
                        <tr>
                            <td><strong>Discussion Date:</strong> <t t-esc="doc.discussion_date"/></td>
                            <td><strong>Signed Date:</strong> <t t-esc="doc.signed_date or '-'"/></td>
                        </tr>
                        <tr>
                            <td><strong>Expiry Date:</strong> <t t-esc="doc.expiry_date or '-'"/></td>
                            <td></td>
                        </tr>
                    </table>

                    <h4>Discussion Notes</h4>
                    <p t-esc="doc.discussion or '-'"/>

                    <h4>Remarks</h4>
                    <p t-esc="doc.remarks or '-'"/>
                </div>
            </t>
        </t>
    </template>

    <template id="report_otm_b2b_mou">
        <t t-call="web.html_container">
            <t t-call="otm_b2b_marketing.report_otm_b2b_mou_document"/>
        </t>
    </template>

</odoo>
