<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_b2b_visit_complete_wizard_form" model="ir.ui.view">
        <field name="name">otm.b2b.visit.complete.wizard.form</field>
        <field name="model">otm.b2b.visit.complete.wizard</field>
        <field name="arch" type="xml">
            <form string="Complete Visit">
                <field name="visit_plan_id" invisible="1"/>
                <field name="visit_record_id" invisible="1"/>
                <group>
                    <field name="institution_id" readonly="1"/>
                    <field name="marketing_activity_type_id"/>
                    <field name="remarks"/>
                    <field name="next_action"/>
                    <field name="next_followup_date"/>
                    <field name="portal_url" widget="url" readonly="1" invisible="not portal_url"
                           string="Share this link for a mobile update"/>
                </group>
                <footer>
                    <button name="action_complete" type="object" string="Mark Visit Done" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_otm_b2b_visit_complete_wizard" model="ir.actions.act_window">
        <field name="name">Complete Visit</field>
        <field name="res_model">otm.b2b.visit.complete.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
