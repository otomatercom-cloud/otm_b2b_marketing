<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_b2b_assign_manager_wizard_form" model="ir.ui.view">
        <field name="name">otm.b2b.assign.manager.wizard.form</field>
        <field name="model">otm.b2b.assign.manager.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Assign Marketing Manager">
                <group>
                    <field name="institution_ids" widget="many2many_tags" readonly="1"/>
                    <field name="marketing_manager_id"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_otm_b2b_assign_manager_wizard" model="ir.actions.act_window">
        <field name="name">Assign Marketing Manager</field>
        <field name="res_model">otm.b2b.assign.manager.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_otm_b2b_institution"/>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
