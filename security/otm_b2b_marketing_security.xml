<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_otm_b2b_marketing" model="ir.module.category">
        <field name="name">B2B Marketing</field>
        <field name="description">Logic School Of Management — B2B Marketing access levels</field>
        <field name="sequence">20</field>
    </record>

    <!-- Odoo 19 removed res.groups.category_id in favour of a dedicated
         res.groups.privilege model (privilege_id -> category_id). See
         ODOO19_RULES.md Rule 6. -->
    <record id="privilege_otm_b2b_marketing" model="res.groups.privilege">
        <field name="name">B2B Marketing</field>
        <field name="category_id" ref="module_category_otm_b2b_marketing"/>
    </record>

    <!-- ==================== GROUPS ==================== -->

    <record id="group_otm_b2b_marketing_executive" model="res.groups">
        <field name="name">Marketing Executive</field>
        <field name="privilege_id" ref="privilege_otm_b2b_marketing"/>
        <field name="comment">Can access only assigned institutions, create visit records,
            and cannot delete approved/completed records.</field>
    </record>

    <record id="group_otm_b2b_marketing_manager" model="res.groups">
        <field name="name">Marketing Manager</field>
        <field name="privilege_id" ref="privilege_otm_b2b_marketing"/>
        <field name="implied_ids" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
        <field name="comment">Can assign institutions, approve visits, and view team reports.</field>
    </record>

    <record id="group_otm_b2b_marketing_head" model="res.groups">
        <field name="name">Marketing Head</field>
        <field name="privilege_id" ref="privilege_otm_b2b_marketing"/>
        <field name="implied_ids" eval="[(4, ref('group_otm_b2b_marketing_manager'))]"/>
        <field name="comment">Full access: Dashboard, Reports, Configuration.</field>
    </record>

    <!-- ==================== RECORD RULES ==================== -->

    <!-- Institution: multi-company -->
    <record id="rule_otm_b2b_institution_company" model="ir.rule">
        <field name="name">B2B Institution: multi-company</field>
        <field name="model_id" ref="model_otm_b2b_institution"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
    </record>

    <!-- Institution: Executives only see institutions assigned to them -->
    <record id="rule_otm_b2b_institution_executive" model="ir.rule">
        <field name="name">B2B Institution: executive sees only assigned</field>
        <field name="model_id" ref="model_otm_b2b_institution"/>
        <field name="domain_force">['|', ('marketing_manager_id', '=', user.id), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
    </record>

    <!-- Institution: Managers/Head see everything in their companies -->
    <record id="rule_otm_b2b_institution_manager" model="ir.rule">
        <field name="name">B2B Institution: manager sees all</field>
        <field name="model_id" ref="model_otm_b2b_institution"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_manager'))]"/>
    </record>

    <!-- Visit Plan: executive sees only their own -->
    <record id="rule_otm_b2b_visit_plan_executive" model="ir.rule">
        <field name="name">B2B Visit Plan: executive sees own</field>
        <field name="model_id" ref="model_otm_b2b_visit_plan"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
    </record>

    <record id="rule_otm_b2b_visit_plan_manager" model="ir.rule">
        <field name="name">B2B Visit Plan: manager sees all</field>
        <field name="model_id" ref="model_otm_b2b_visit_plan"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_manager'))]"/>
    </record>

    <!-- Visit Record: executive sees only their own -->
    <record id="rule_otm_b2b_visit_record_executive" model="ir.rule">
        <field name="name">B2B Visit Record: executive sees own</field>
        <field name="model_id" ref="model_otm_b2b_visit_record"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
    </record>

    <record id="rule_otm_b2b_visit_record_manager" model="ir.rule">
        <field name="name">B2B Visit Record: manager sees all</field>
        <field name="model_id" ref="model_otm_b2b_visit_record"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_manager'))]"/>
    </record>

    <!-- Lead / Seminar / MOU: company-level visibility for everyone with access -->
    <record id="rule_otm_b2b_lead_company" model="ir.rule">
        <field name="name">B2B Lead: multi-company</field>
        <field name="model_id" ref="model_otm_b2b_lead"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
    </record>

    <record id="rule_otm_b2b_seminar_company" model="ir.rule">
        <field name="name">B2B Seminar: multi-company</field>
        <field name="model_id" ref="model_otm_b2b_seminar"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
    </record>

    <record id="rule_otm_b2b_mou_company" model="ir.rule">
        <field name="name">B2B MOU: multi-company</field>
        <field name="model_id" ref="model_otm_b2b_mou"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_otm_b2b_marketing_executive'))]"/>
    </record>

</odoo>
